# =============================================================
# BlendLink Frontend — Environment Variables
# =============================================================
# Set these in Cloudflare Pages: Settings > Environment Variables
# =============================================================

# Backend API URL (your Render deployment URL)
REACT_APP_API_URL=https://blendlink-api.onrender.com

# Stripe publishable key (safe for frontend — this is NOT the secret key)
REACT_APP_STRIPE_PUBLISHABLE_KEY=pk_live_XXXXXXXXXXXXXXXXXXXX
