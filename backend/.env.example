# =============================================================
# BlendLink Backend — Environment Variables
# =============================================================
# Copy this file to .env and fill in your values
#
# IMPORTANT: BlendLink runs on its OWN dedicated MongoDB cluster
# separate from Zapcodes. Same Atlas account, different cluster.
# =============================================================

# ==================== MONGODB (REQUIRED) ====================
MONGODB_URI=mongodb+srv://blendlink_admin:YOUR_PASSWORD_HERE@blendlink-production.XXXXX.mongodb.net/blendlink_db

# Alternative: Split config
# MONGO_URL=mongodb+srv://blendlink_admin:YOUR_PASSWORD_HERE@blendlink-production.XXXXX.mongodb.net
# DB_NAME=blendlink_db

# ==================== JWT (REQUIRED) ========================
JWT_SECRET=CHANGE_ME_GENERATE_A_RANDOM_STRING
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# ==================== STRIPE (REQUIRED) =====================
STRIPE_SECRET_KEY=sk_live_XXXXXXXXXXXXXXXXXXXX
STRIPE_PUBLISHABLE_KEY=pk_live_XXXXXXXXXXXXXXXXXXXX

STRIPE_BRONZE_PRICE_ID=price_XXXXXXXXXXXXXXXXXXXX
STRIPE_SILVER_PRICE_ID=price_XXXXXXXXXXXXXXXXXXXX
STRIPE_GOLD_PRICE_ID=price_XXXXXXXXXXXXXXXXXXXX
STRIPE_DIAMOND_PRICE_ID=price_XXXXXXXXXXXXXXXXXXXX

STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXXXXXX

# ==================== CORS (REQUIRED) =======================
CORS_ORIGINS=https://blendlink.pages.dev,https://blendlink.net

# ==================== OPTIONAL SERVICES ====================
# RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXX
# OPENAI_API_KEY=sk-XXXXXXXXXXXXXXXXXXXX
# GOOGLE_API_KEY=XXXXXXXXXXXXXXXXXXXX
# REDIS_URL=redis://default:XXXX@your-redis-host:6379
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_EMAIL=admin@blendlink.net
# GOOGLE_OAUTH_SESSION_URL=https://your-oauth-endpoint.com/auth/session-data
